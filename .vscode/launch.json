{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Nexus-e Debugger",
            "type": "debugpy",
            "request": "launch",
            "module": "src.nexus_e.app",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Current File (Integrated Terminal)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
    ]
}