{
	// Place your nexus-e-framework workspace snippets here. Each snippet is defined under a snippet name and has a scope, prefix, body and 
	// description. Add comma separated ids of the languages where the snippet is applicable in the scope field. If scope 
	// is left empty or omitted, the snippet gets applied to all languages. The prefix is what is 
	// used to trigger the snippet and the body will be expanded and inserted. Possible variables are: 
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. 
	// Placeholders with the same ids are connected.
	// Example:
	// "Print to console": {
	// 	"scope": "javascript,typescript",
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	"test module": {
		"scope": "python",
		"prefix": "test module",
		"body": [
			"import pytest",
			"",
			"class Test${1:ModuleName}:",
			"",
			"    def test_${2}(self):",
			"        # Arrange",
			"        $0",
			"        # Act",
			"        # Assert",
			"        assert False"
		],
		"description": "Test Python module"
	},
	"test method": {
		"scope": "python",
		"prefix": "test method",
		"body": [
			"def test_$1(self):",
			"    # Arrange",
			"    $0",
			"    # Act",
			"    # Assert",
			"    assert False"
		],
		"description": "Arrange, Act, Assert test template"
	},
	"test parametrise": {
		"scope": "python",
		"prefix": "test method parametrized",
		"body": [
			"@pytest.mark.parametrize((\"${2:parameter}\"),",
			"    [",
			"        (\"${4:value}\"),",
			"    ]",
			")",
			"def test_$1(",
			"    self,",
			"    ${2:parameter}: ${3:type}",
			"):",
			"    # Arrange",
			"    $0",
			"    # Act",
			"    # Assert",
			"    assert False"
		],
		"description": "Parametrized test template"
	},
}